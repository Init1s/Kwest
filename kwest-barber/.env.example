# Required for local dev and Playwright tests. Copy to `.env.local` and fill in.
# Production values are set in .github/workflows/deploy.yml (GH Pages) and
# the Amplify console (AWS). Do not commit .env.local — it is gitignored.

NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_SQUIRE_BOOKING_URL=https://getsquire.com/booking/book/a-barbershop-called-kwest-boca-raton/barber/luc-coriolan/services
NEXT_PUBLIC_SITE_URL=https://kwestthebarber.com

# Optional. Without it the Instagram section renders a placeholder.
INSTAGRAM_ACCESS_TOKEN=
